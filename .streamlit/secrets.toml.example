# Streamlit Secrets Configuration
# Copy this file to secrets.toml and fill in your values

# Anthropic Claude API Key (optional - for AI chat feature)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY = "your-anthropic-api-key-here"

# Note: In production, set these via Streamlit Cloud dashboard
# Go to: https://share.streamlit.io/ -> Your App -> ⋮ -> Settings -> Secrets
